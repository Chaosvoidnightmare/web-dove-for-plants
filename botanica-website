<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Botanica.ai - Plant Clinic</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            dark: '#1e3329',
                            light: '#f5f5f0',
                            accent: '#cd7b67',
                            card: '#ffffff'
                        }
                    },
                    fontFamily: {
                        serif: ['"Playfair Display"', 'serif'],
                        sans: ['Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body { background-color: #f5f5f0; }
        .hero-bg {
            background-image: linear-gradient(to right, rgba(30, 51, 41, 0.8), rgba(30, 51, 41, 0.3)), url('https://images.unsplash.com/photo-1585320806055-61b9d40b4cce?auto=format&fit=crop&w=1600&q=80');
            background-size: cover;
            background-position: center;
        }
    </style>
</head>
<body class="font-sans text-brand-dark antialiased p-4 md:p-8 max-w-7xl mx-auto">

    <nav class="flex justify-between items-center mb-8">
        <div class="flex items-center space-x-2">
            <div class="w-8 h-8 bg-brand-dark rounded-full flex items-center justify-center text-white">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
            </div>
            <span class="text-xl font-serif font-semibold">Botanica<span class="text-gray-400">.ai</span></span>
        </div>
        <div class="hidden md:flex space-x-8 text-sm items-center text-gray-500">
            <a href="#" class="bg-brand-dark text-white px-4 py-2 rounded-full font-medium">Dashboard</a>
            <a href="#" class="hover:text-brand-dark transition">Library</a>
            <a href="#" class="hover:text-brand-dark transition">Plant Doctor</a>
            <a href="#" class="hover:text-brand-dark transition">My Garden</a>
            <a href="#" class="hover:text-brand-dark transition">History</a>
        </div>
    </nav>

    <header class="hero-bg rounded-3xl p-8 md:p-16 text-white mb-6 h-[450px] flex flex-col justify-center">
        <p class="text-xs tracking-widest uppercase mb-4 opacity-80">Botanica AI - Greenhouse 01</p>
        <h1 class="text-5xl md:text-7xl font-serif mb-6 max-w-2xl leading-tight">
            The clinic where <br><span class="italic">plants are heard.</span>
        </h1>
        <p class="max-w-md text-sm opacity-90 mb-8 leading-relaxed">
            Catalog your green companions, monitor local climate & air, and let an AI pathologist diagnose ailments from a single photograph.
        </p>
        <div class="flex space-x-4">
            <button class="bg-brand-accent hover:bg-opacity-90 text-white px-6 py-3 rounded-full text-sm font-medium transition flex items-center space-x-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                <span>Diagnose a plant</span>
            </button>
            <button class="bg-white bg-opacity-20 hover:bg-opacity-30 backdrop-blur-md text-white border border-white border-opacity-30 px-6 py-3 rounded-full text-sm font-medium transition flex items-center space-x-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                <span>Explore library</span>
            </button>
        </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        
        <div class="md:col-span-6 bg-white rounded-3xl p-8 shadow-sm">
            <div class="flex justify-between items-start mb-8">
                <div>
                    <p class="text-xs font-semibold tracking-widest text-gray-400 uppercase mb-2">Local Climate</p>
                    <h2 class="text-3xl font-serif mb-1">Partly cloudy</h2>
                    <p class="text-sm text-gray-500 flex items-center">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        New York, USA
                    </p>
                </div>
                <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path></svg>
            </div>

            <div class="mb-8">
                <span class="text-6xl font-serif">7<span class="text-3xl align-top block-inline mt-2">°C</span></span>
            </div>

            <div class="grid grid-cols-3 gap-4 mb-6">
                <div class="bg-brand-light p-4 rounded-2xl">
                    <p class="text-xs text-gray-500 mb-1">Humidity</p>
                    <p class="font-medium">86%</p>
                </div>
                <div class="bg-brand-light p-4 rounded-2xl">
                    <p class="text-xs text-gray-500 mb-1">Wind</p>
                    <p class="font-medium">9 km/h</p>
                </div>
                <div class="bg-brand-light p-4 rounded-2xl">
                    <p class="text-xs text-gray-500 mb-1">Air (AQI)</p>
                    <p class="font-medium">35 <span class="text-gray-400 text-xs font-normal">Good</span></p>
                </div>
            </div>

            <div class="relative flex items-center">
                <svg class="w-5 h-5 absolute left-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                <input type="text" placeholder="Search city or region..." class="w-full bg-brand-light rounded-full py-3 pl-12 pr-20 text-sm focus:outline-none focus:ring-2 focus:ring-brand-dark">
                <button class="absolute right-1 bg-brand-dark text-white px-4 py-2 rounded-full text-xs font-medium">Find</button>
            </div>
        </div>

        <div class="md:col-span-3 bg-white rounded-3xl p-8 shadow-sm flex flex-col justify-between">
            <div class="flex justify-between items-start">
                <p class="text-xs font-semibold tracking-widest text-gray-400 uppercase">My Garden</p>
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
            </div>
            <div>
                <p class="text-6xl font-serif mb-2">0</p>
                <p class="text-sm text-gray-500">plants you tend</p>
            </div>
        </div>

        <div class="md:col-span-3 bg-white rounded-3xl p-8 shadow-sm flex flex-col justify-between">
            <div class="flex justify-between items-start">
                <p class="text-xs font-semibold tracking-widest text-gray-400 uppercase">Diagnoses</p>
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
            </div>
            <div>
                <p class="text-6xl font-serif mb-2">0</p>
                <p class="text-sm text-gray-500">AI consultations</p>
            </div>
        </div>

    </div>
</body>
</html>
